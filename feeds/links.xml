---
layout: empty
permalink: /links.xml
---
<?xml version="1.0" encoding="utf-8"?>
{% assign pub_date = site.time | date: "%Y-%m-%dT%H:%M:%SZ" %}
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en">
  <title>{{ site.owner.name }} - {{ site.title }} - linked/quote posts</title>
  <subtitle type="html">{{ site.description }}</subtitle>
  <link rel="self" type="application/atom+xml" href="{{ site.url }}/links.xml" />
  <link rel="alternate" type="text/html" href="{{ site.url }}" />
  <generator>Jekyll</generator>
  <rights>{{ site.owner.name }}</rights>
  <updated>{{ pub_date }}</updated>
  <author>
    <name>{{ site.owner.name }}</name>
    <email>{{ site.owner.email }}</email>
    <uri>{{ site.owner.uri }}/</uri>
  </author>
  <id>{{ site.url }}/</id>
  {% assign posts_only = site.posts | where_exp: "post", "post.type == 'linked'" %}
  {% for post in posts_only  %}
     {% assign build_date = post.date | date: "%Y-%m-%dT%H:%M:%SZ" %}
     {% assign updated_date = post.modified | date: "%Y-%m-%dT%H:%M:%SZ" %}
     {% assign min = 1 %}
     {% assign max = site.data.offers.size %}
     {% assign diff = max | minus: min %}
     {% assign item = "now" | date: "%N" | modulo: diff | plus: min %}
     {% assign offer = site.data.offers[item] %}
      <entry>
        <title type="html"><![CDATA[ > {{ post.title | cdata_escape }}]]></title>
        <link rel="alternate" type="text/html" href="{{ site.url }}{{ post.url }}" />
        <id>{{ site.url }}{{ post.id }}</id>
        <published>{{ build_date }}</published>
        <updated>{% if post.modified %}{{ updated_date }}{% else %}{{ build_date }}{% endif %}</updated>
        <author>
          <name>{% if post.cited %}Quoting {{ post.cited }}{% else %}{{ site.owner.name }}{% endif %}</name>
          <uri>{% if post.link %}{{ post.link }}{% else %}{{ site.url }}{{ post.url }}{% endif %}</uri>
        </author>
        <content type="html"><![CDATA[
          {{ post.content }}
          <p><center>***</center></p>
          <p> // Published {{ post.date | date: "%Y-%m-%d" }}, with {{ post.content | number_of_words }} words.</p>
          <hr/>
          <p>💬 Thanks for keeping RSS alive. If you have an RSS feed please share it with me on any of these <a href="https://links.thechels.uk">socials</a>. If you love RSS you may like my <a href="/rss.xml">secret RSS only feed</a> in which posts don't appear on the website.</p>
          <p>If you get value from this site, please share this post with someone you think will like it and support me with a <a href="https://ko-fi.com/thechelsuk">ko-fi</a>.</p>
          <p>Finally, here is a special sponsor/advert link just for you; <a rel="sponsored" href="{{offer.link}}">{{offer.title}}</a><br/>[T&Cs apply].</p>
        ]]></content>
      </entry>
  {% endfor %}
</feed>
